EXCHANGE=kraken
API_KEY=
API_SECRET=

SYMBOL=BTCUSDT
TIMEFRAME=1h

# All values below default to SYMBOL's confirmed baseline (see bot.py's
# BASELINES dict / CLAUDE.md / Backtest/VALIDATED_PARAMETERS.md) if unset.
# Uncomment and set explicitly only to override that default.
# RSI_PERIOD=14
# RSI_ENTRY_THRESHOLD=28
# RSI_EXIT_THRESHOLD=29
# ENABLE_ATR_STOP=true
# ATR_PERIOD=10
# ATR_MULTIPLIER=2.0
# STOP_LOSS_PCT=5.5
# ENABLE_RANGE_FILTER=true
# RANGE_MA_PERIOD=200
# RANGE_MAX_DISTANCE_PCT=2.0

POSITION_SIZE_R=0.5
POLL_INTERVAL_SECONDS=60

DRY_RUN=true
